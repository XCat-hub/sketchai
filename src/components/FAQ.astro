---
const faqs = [
  {
    question: 'Do I need a Google account?',
    answer:
      'Yes. Google Sign-In is required to use AI generation features, manage your quota, and sync subscription status.',
  },
  {
    question: 'How often does my AI quota reset?',
    answer:
      'Free users receive 3 AI generations per month. Plus members receive 100+ generations per month. Your quota resets at the start of each billing period.',
  },
  {
    question: 'How do I cancel my subscription?',
    answer:
      'Open Google Play → Payments & subscriptions → Subscriptions → Sketch AI, then tap Cancel. You keep Plus benefits until the current period ends.',
  },
  {
    question: 'Where is my artwork stored?',
    answer:
      'Drawings are stored locally on your device by default. Plus members can optionally back up to Google Drive. AI-generated images on our servers are automatically deleted after 24 hours.',
  },
  {
    question: 'Is the app safe for children?',
    answer:
      'Sketch AI includes built-in NSFW content filtering. The app is intended for users aged 13 and older.',
  },
  {
    question: 'Which languages are supported?',
    answer:
      'The app supports 15+ languages including English, Chinese (Simplified & Traditional), Japanese, Korean, Arabic, Spanish, French, German, and more.',
  },
];
---

<section class="section alt-bg" id="faq">
  <div class="container">
    <h2 class="section-title">FAQ</h2>
    <p class="section-subtitle">Common questions about Sketch AI.</p>
    <div class="faq-list">
      {
        faqs.map((item) => (
          <details class="faq-item card">
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq-list {
    display: grid;
    gap: 0.75rem;
    max-width: 42rem;
    margin-inline: auto;
  }

  .faq-item {
    padding: 0;
    overflow: hidden;
  }

  .faq-item summary {
    padding: 1rem 1.25rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: '+';
    float: right;
    font-weight: 400;
    color: var(--color-primary);
  }

  .faq-item[open] summary::after {
    content: '−';
  }

  .faq-item p {
    margin: 0;
    padding: 0 1.25rem 1rem;
    font-size: 0.9375rem;
    color: var(--color-on-surface-variant);
  }
</style>
