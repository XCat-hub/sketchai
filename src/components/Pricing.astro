---
import { SITE } from '../data/site';

const rows = [
  { feature: 'Multi-layer drawing canvas', free: true, plus: true },
  { feature: 'AI sketch-to-image generation', free: true, plus: true },
  { feature: 'Text-to-coloring-page mode', free: true, plus: true },
  { feature: 'AI generations per month', free: '3', plus: '100+' },
  { feature: 'Ad-free experience', free: false, plus: true },
  { feature: 'Google Drive cloud backup', free: false, plus: true },
  { feature: 'HD watermark-free export', free: false, plus: true },
  { feature: 'All brushes & art styles', free: 'Limited', plus: true },
];
---

<section class="section" id="pricing">
  <div class="container">
    <h2 class="section-title">Free &amp; Plus</h2>
    <p class="section-subtitle">
      Start for free, upgrade when you need more AI generations and premium tools.
      Prices are shown in Google Play at checkout.
    </p>

    <div class="pricing-grid">
      <article class="plan card">
        <h3>Free</h3>
        <p class="plan-price">$0</p>
        <p class="plan-note">3 AI generations per month · includes ads</p>
        <ul>
          <li>Full drawing canvas</li>
          <li>Basic AI features</li>
          <li>Local artwork storage</li>
        </ul>
      </article>

      <article class="plan card plan-plus">
        <span class="plan-badge">Recommended</span>
        <h3>SketchAI Plus</h3>
        <p class="plan-price">See Google Play</p>
        <p class="plan-note">Weekly · Monthly · Yearly plans available</p>
        <ul>
          <li>100+ AI generations per month</li>
          <li>No ads</li>
          <li>Google Drive backup &amp; restore</li>
          <li>HD export without watermark</li>
        </ul>
        <a class="btn btn-primary" href={SITE.playStoreUrl} target="_blank" rel="noopener noreferrer">
          Upgrade on Google Play
        </a>
      </article>
    </div>

    <div class="comparison-wrap">
      <table class="comparison">
        <thead>
          <tr>
            <th scope="col">Feature</th>
            <th scope="col">Free</th>
            <th scope="col">Plus</th>
          </tr>
        </thead>
        <tbody>
          {
            rows.map((row) => (
              <tr>
                <td>{row.feature}</td>
                <td>{typeof row.free === 'boolean' ? (row.free ? '✓' : '—') : row.free}</td>
                <td>{typeof row.plus === 'boolean' ? (row.plus ? '✓' : '—') : row.plus}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <p class="pricing-disclaimer">
      Subscriptions auto-renew and can be cancelled anytime in Google Play account settings.
      A Google account is required for AI generation features.
    </p>
  </div>
</section>

<style>
  .pricing-grid {
    display: grid;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  @media (min-width: 640px) {
    .pricing-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .plan h3 {
    margin: 0 0 0.25rem;
    font-size: 1.25rem;
  }

  .plan-price {
    margin: 0;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .plan-note {
    margin: 0.25rem 0 1rem;
    font-size: 0.875rem;
    color: var(--color-on-surface-variant);
  }

  .plan ul {
    margin: 0 0 1.25rem;
    padding-left: 1.125rem;
    font-size: 0.9375rem;
    color: var(--color-on-surface-variant);
  }

  .plan-plus {
    border: 2px solid var(--color-primary);
    position: relative;
  }

  .plan-badge {
    position: absolute;
    top: -0.75rem;
    right: 1rem;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    background: var(--color-premium);
    color: #1c1b1f;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .comparison-wrap {
    overflow-x: auto;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-1);
  }

  .comparison {
    width: 100%;
    border-collapse: collapse;
    background: var(--color-surface-container);
    font-size: 0.9375rem;
  }

  .comparison th,
  .comparison td {
    padding: 0.875rem 1rem;
    text-align: left;
    border-bottom: 1px solid color-mix(in srgb, var(--color-outline) 20%, transparent);
  }

  .comparison th {
    background: var(--color-surface-container-high);
    font-weight: 600;
  }

  .comparison td:not(:first-child) {
    text-align: center;
    width: 6rem;
  }

  .pricing-disclaimer {
    margin: 1.5rem 0 0;
    text-align: center;
    font-size: 0.8125rem;
    color: var(--color-on-surface-variant);
  }
</style>
