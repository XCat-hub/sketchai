---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('legal', 'privacy');
if (!entry) {
  throw new Error('Privacy policy content not found');
}
const { Content } = await render(entry);
---

<BaseLayout title="Privacy Policy" description="Sketch AI Privacy Policy — how we collect, use, and protect your information.">
  <section class="section legal">
    <div class="container prose">
      <Content />
    </div>
  </section>
</BaseLayout>

<style>
  .legal {
    padding-top: 2rem;
    padding-bottom: 3rem;
  }
</style>
